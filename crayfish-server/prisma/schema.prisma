// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// 1. Tenants (多租户基础)
model Tenant {
  id             String         @id @default(uuid())
  name           String
  status         Int            @default(1) // 1: 正常, 0: 禁用
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  users          User[]
  tenantModules  TenantModule[]
  tasks          Task[]
  messages       Message[]
  reports        Report[]
  systemConfigs  SystemConfig[]
}

// 2. Users (用户)
model User {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  nickname  String?
  avatar    String?
  email     String?
  phone     String?
  status    Int        @default(1)
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  roles     UserRole[]
  tasks     Task[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// 3. Roles (角色)
model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  permissions RolePermission[]
  userRoles   UserRole[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// 4. Permissions (权限)
model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  type        String // menu, button, api
  path        String? // 路由路径或API路径
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// 5. Role-Permission Join
model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// 6. User-Role Join
model UserRole {
  userId String
  user   User   @relation(fields: [userId], references: [id])
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

// 7. Modules (15大模块定义)
model Module {
  id            String         @id @default(uuid())
  moduleCode    String         @unique
  moduleName    String
  routePath     String
  icon          String?
  sort          Int            @default(0)
  status        Int            @default(1) // 1: 启用, 0: 禁用, 2: 开发中
  description   String?
  tenantModules TenantModule[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// 8. Tenant-Module Mapping (租户开通的模块)
model TenantModule {
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id])
  expiredAt DateTime?
  createdAt DateTime @default(now())

  @@id([tenantId, moduleId])
}

// 9. Tasks (统一任务中心)
model Task {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  moduleCode   String // 来源模块编码
  taskType     String // 任务类型 (如: 爬虫, 推送, 分析)
  taskName     String
  status       String // pending, running, success, failed
  inputPayload Json?
  outputOutput Json?
  errorMessage String?   @db.Text
  createdBy    String
  user         User      @relation(fields: [createdBy], references: [id])
  logs         TaskLog[]
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
}

// 10. Task Logs (任务详情日志)
model TaskLog {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  content   String   @db.Text
  level     String   @default("info") // info, warn, error
  createdAt DateTime @default(now())
}

// 11. Messages (消息中心)
model Message {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  moduleCode String?
  title      String
  content    String   @db.Text
  type       String // system, module, error
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// 12. Reports (数据报表中心)
model Report {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  moduleCode String
  title      String
  url        String
  reportType String // pdf, excel, html
  createdAt  DateTime @default(now())
}

// 13. Files (文件中心)
model File {
  id         String   @id @default(uuid())
  name       String
  url        String
  size       Int
  mimeType   String
  moduleCode String?
  createdAt  DateTime @default(now())
}

// 14. System Configs (全局/租户配置)
model SystemConfig {
  id          String   @id @default(uuid())
  tenantId    String? // 为空则是全局配置
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  configKey   String   @unique
  configValue String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

// 15. Menus (菜单管理)
model Menu {
  id         String   @id @default(uuid())
  parentId   String?
  title      String
  path       String?
  icon       String?
  sort       Int      @default(0)
  permission String? // 关联的权限编码码
  status     Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
